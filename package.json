      {
        "command": "gitShortcutsDoctor.previousConflict",
        "title": "Git Shortcuts Doctor: Previous Conflict",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.gitDoctor",
        "title": "Git Shortcuts Doctor: Diagnose Git State",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.runCustomGit",
        "title": "Git Shortcuts Doctor: Run Custom Git Command",
        "category": "Git Shortcuts Doctor"
      }
    ],
    "keybindings": [
      {
        "command": "gitShortcutsDoctor.openDashboard",
        "key": "ctrl+alt+g d",
        "mac": "cmd+alt+g d"
      },
      {
        "command": "gitShortcutsDoctor.startFeature",
        "key": "ctrl+alt+g w",
        "mac": "cmd+alt+g w"
      },
      {
        "command": "gitShortcutsDoctor.startPrBranch",
        "key": "ctrl+alt+g j",
        "mac": "cmd+alt+g j"
      },
      {
        "command": "gitShortcutsDoctor.syncWithTargetBranch",
        "key": "ctrl+alt+g i",
        "mac": "cmd+alt+g i"
      },
      {
        "command": "gitShortcutsDoctor.checkPrReadiness",
        "key": "ctrl+alt+g v",
        "mac": "cmd+alt+g v"
      },
      {
        "command": "gitShortcutsDoctor.preparePr",
        "key": "ctrl+alt+g shift+v",
        "mac": "cmd+alt+g shift+v"
      },
      {
        "command": "gitShortcutsDoctor.createPr",
        "key": "ctrl+alt+g shift+j",
        "mac": "cmd+alt+g shift+j"
      },
      {
        "command": "gitShortcutsDoctor.syncBranch",
        "key": "ctrl+alt+g y",
        "mac": "cmd+alt+g y"
      },
      {
        "command": "gitShortcutsDoctor.saveWorkQuickly",
        "key": "ctrl+alt+g k",
        "mac": "cmd+alt+g k"
      },
      {
        "command": "gitShortcutsDoctor.undoLastMistake",
        "key": "ctrl+alt+g z",
        "mac": "cmd+alt+g z"
      },
      {
        "command": "gitShortcutsDoctor.conflictCenter",
        "key": "ctrl+alt+g q",
        "mac": "cmd+alt+g q"
      },
      {
        "command": "gitShortcutsDoctor.gitStatus",
        "key": "ctrl+alt+g s",
        "mac": "cmd+alt+g s"
      },
      {
        "command": "gitShortcutsDoctor.fetchAll",
        "key": "ctrl+alt+g f",
        "mac": "cmd+alt+g f"
      },
      {
        "command": "gitShortcutsDoctor.pullLatest",
        "key": "ctrl+alt+g u",
        "mac": "cmd+alt+g u"
      },
      {
        "command": "gitShortcutsDoctor.pullRebase",
        "key": "ctrl+alt+g l",
        "mac": "cmd+alt+g l"
      },
      {
        "command": "gitShortcutsDoctor.addAll",
        "key": "ctrl+alt+g a",
        "mac": "cmd+alt+g a"
      },
      {
        "command": "gitShortcutsDoctor.addCurrentFile",
        "key": "ctrl+alt+g .",
        "mac": "cmd+alt+g ."
      },
      {
        "command": "gitShortcutsDoctor.commit",
        "key": "ctrl+alt+g c",
        "mac": "cmd+alt+g c"
      },
      {
        "command": "gitShortcutsDoctor.commitAmend",
        "key": "ctrl+alt+g shift+c",
        "mac": "cmd+alt+g shift+c"
      },
      {
        "command": "gitShortcutsDoctor.push",
        "key": "ctrl+alt+g p",
        "mac": "cmd+alt+g p"
      },
      {
        "command": "gitShortcutsDoctor.pushForceLease",
        "key": "ctrl+alt+g shift+p",
        "mac": "cmd+alt+g shift+p"
      },
      {
        "command": "gitShortcutsDoctor.createBranch",
        "key": "ctrl+alt+g n",
        "mac": "cmd+alt+g n"
      },
      {
        "command": "gitShortcutsDoctor.checkoutBranch",
        "key": "ctrl+alt+g b",
        "mac": "cmd+alt+g b"
      },
      {
        "command": "gitShortcutsDoctor.mergeBranch",
        "key": "ctrl+alt+g e",
        "mac": "cmd+alt+g e"
      },
      {
        "command": "gitShortcutsDoctor.stashPush",
        "key": "ctrl+alt+g t",
        "mac": "cmd+alt+g t"
      },
      {
        "command": "gitShortcutsDoctor.stashPop",
        "key": "ctrl+alt+g o",
        "mac": "cmd+alt+g o"
      },
      {
        "command": "gitShortcutsDoctor.abortMerge",
        "key": "ctrl+alt+g m",
        "mac": "cmd+alt+g m"
      },
      {
        "command": "gitShortcutsDoctor.abortRebase",
        "key": "ctrl+alt+g r",
        "mac": "cmd+alt+g r"
      },
      {
        "command": "gitShortcutsDoctor.acceptCurrent",
        "key": "ctrl+alt+g 1",
        "mac": "cmd+alt+g 1",
        "when": "isMergeEditor || mergeConflictsEnabled"
      },
      {
        "command": "gitShortcutsDoctor.acceptIncoming",
        "key": "ctrl+alt+g 2",
        "mac": "cmd+alt+g 2",
        "when": "isMergeEditor || mergeConflictsEnabled"
      },
      {
        "command": "gitShortcutsDoctor.acceptBoth",
        "key": "ctrl+alt+g 3",
        "mac": "cmd+alt+g 3",
        "when": "isMergeEditor || mergeConflictsEnabled"
      },
      {
        "command": "gitShortcutsDoctor.nextConflict",
        "key": "ctrl+alt+g ]",
        "mac": "cmd+alt+g ]"
      },
      {
        "command": "gitShortcutsDoctor.previousConflict",
        "key": "ctrl+alt+g [",
        "mac": "cmd+alt+g ["
      },
      {
        "command": "gitShortcutsDoctor.gitDoctor",
        "key": "ctrl+alt+g h",
        "mac": "cmd+alt+g h"
      },
      {
        "command": "gitShortcutsDoctor.runCustomGit",
        "key": "ctrl+alt+g x",
        "mac": "cmd+alt+g x"
      }
    ],
    "configuration": {
      "title": "Git Shortcuts Doctor",
      "properties": {
        "gitShortcutsDoctor.defaultTargetBranch": {
          "type": "string",
          "default": "main",
          "description": "Default target branch used in PR workflows such as start PR branch, sync with target branch, and PR readiness."
        },
        "gitShortcutsDoctor.preferredPrMode": {
          "type": "string",
          "enum": [
            "auto",
            "cli",
            "browser"
          ],
          "default": "auto",
          "description": "Preferred PR creation mode. Auto uses gh/glab when available and falls back to browser."
        },
        "gitShortcutsDoctor.prTitleTemplate": {
          "type": "string",
          "default": "{firstCommit}",
          "description": "Template for suggested PR titles. Supported placeholders: {branch}, {target}, {firstCommit}, {commitCount}."
        },
        "gitShortcutsDoctor.prBodyTemplate": {
          "type": "string",
          "default": "Target branch: {target}\\n\\nSummary\\n- Update this section before submitting the PR.\\n\\nIncluded commits\\n{commitBullets}\\n\\nWorking tree clean: {workingTreeClean}",
          "description": "Template for suggested PR bodies. Supported placeholders: {branch}, {target}, {firstCommit}, {commitCount}, {commitBullets}, {workingTreeClean}."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "gitShortcutsDoctor.openDashboard"
        },
        {
          "command": "gitShortcutsDoctor.gitDoctor"
        }
      ]
    }
  },
  "scripts": {
    "lint": "node -e \"require('./src/extension.js')\"",
    "check": "node --check src/extension.js"
  },
  "devDependencies": {}
}
