{
  "name": "git-shortcuts-doctor",
  "displayName": "Git Shortcuts Doctor",
  "description": "A VS Code Git workflow assistant with shortcuts, conflict recovery, PR readiness checks, and PR creation for GitHub and GitLab.",
  "version": "0.0.1",
  "publisher": "AreeshaHabib",
  "repository": {
    "type": "git",
    "url": "https://github.com/AreeshaHab/git-shortcuts-doctor.git"
  },
  "homepage": "https://github.com/AreeshaHab/git-shortcuts-doctor",
  "bugs": {
    "url": "https://github.com/AreeshaHab/git-shortcuts-doctor/issues"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "keywords": [
    "git",
    "pull-request",
    "merge-conflict",
    "github",
    "gitlab",
    "workflow",
    "source-control"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Source Control",
    "Other"
  ],
  "main": "./src/extension.js",
  "markdown": "github",
  "activationEvents": [
    "onCommand:gitShortcutsDoctor.openDashboard",
    "onCommand:gitShortcutsDoctor.startFeature",
    "onCommand:gitShortcutsDoctor.startPrBranch",
    "onCommand:gitShortcutsDoctor.syncWithTargetBranch",
    "onCommand:gitShortcutsDoctor.checkPrReadiness",
    "onCommand:gitShortcutsDoctor.preparePr",
    "onCommand:gitShortcutsDoctor.createPr",
    "onCommand:gitShortcutsDoctor.syncBranch",
    "onCommand:gitShortcutsDoctor.saveWorkQuickly",
    "onCommand:gitShortcutsDoctor.undoLastMistake",
    "onCommand:gitShortcutsDoctor.conflictCenter",
    "onCommand:gitShortcutsDoctor.gitStatus",
    "onCommand:gitShortcutsDoctor.fetchAll",
    "onCommand:gitShortcutsDoctor.pullLatest",
    "onCommand:gitShortcutsDoctor.pullRebase",
    "onCommand:gitShortcutsDoctor.addAll",
    "onCommand:gitShortcutsDoctor.addCurrentFile",
    "onCommand:gitShortcutsDoctor.commit",
    "onCommand:gitShortcutsDoctor.commitAmend",
    "onCommand:gitShortcutsDoctor.push",
    "onCommand:gitShortcutsDoctor.pushForceLease",
    "onCommand:gitShortcutsDoctor.createBranch",
    "onCommand:gitShortcutsDoctor.checkoutBranch",
    "onCommand:gitShortcutsDoctor.mergeBranch",
    "onCommand:gitShortcutsDoctor.stashPush",
    "onCommand:gitShortcutsDoctor.stashPop",
    "onCommand:gitShortcutsDoctor.abortMerge",
    "onCommand:gitShortcutsDoctor.abortRebase",
    "onCommand:gitShortcutsDoctor.runCustomGit",
    "onCommand:gitShortcutsDoctor.acceptCurrent",
    "onCommand:gitShortcutsDoctor.acceptIncoming",
    "onCommand:gitShortcutsDoctor.acceptBoth",
    "onCommand:gitShortcutsDoctor.nextConflict",
    "onCommand:gitShortcutsDoctor.previousConflict",
    "onCommand:gitShortcutsDoctor.gitDoctor"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gitShortcutsDoctor.openDashboard",
        "title": "Git Shortcuts Doctor: Open Dashboard",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.startFeature",
        "title": "Git Shortcuts Doctor: Start Feature",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.startPrBranch",
        "title": "Git Shortcuts Doctor: Start PR Branch",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.syncWithTargetBranch",
        "title": "Git Shortcuts Doctor: Sync With Target Branch",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.checkPrReadiness",
        "title": "Git Shortcuts Doctor: Check PR Readiness",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.preparePr",
        "title": "Git Shortcuts Doctor: Prepare PR",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.createPr",
        "title": "Git Shortcuts Doctor: Create PR",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.syncBranch",
        "title": "Git Shortcuts Doctor: Sync Branch",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.saveWorkQuickly",
        "title": "Git Shortcuts Doctor: Save Work Quickly",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.undoLastMistake",
        "title": "Git Shortcuts Doctor: Undo Last Mistake",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.conflictCenter",
        "title": "Git Shortcuts Doctor: Conflict Center",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.gitStatus",
        "title": "Git Shortcuts Doctor: Git Status",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.fetchAll",
        "title": "Git Shortcuts Doctor: Fetch All",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.pullLatest",
        "title": "Git Shortcuts Doctor: Pull Latest",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.pullRebase",
        "title": "Git Shortcuts Doctor: Pull Rebase",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.addAll",
        "title": "Git Shortcuts Doctor: Add All",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.addCurrentFile",
        "title": "Git Shortcuts Doctor: Add Current File",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.commit",
        "title": "Git Shortcuts Doctor: Commit",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.commitAmend",
        "title": "Git Shortcuts Doctor: Commit Amend",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.push",
        "title": "Git Shortcuts Doctor: Push",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.pushForceLease",
        "title": "Git Shortcuts Doctor: Push Force With Lease",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.createBranch",
        "title": "Git Shortcuts Doctor: Create Branch",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.checkoutBranch",
        "title": "Git Shortcuts Doctor: Checkout Branch",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.mergeBranch",
        "title": "Git Shortcuts Doctor: Merge Branch",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.stashPush",
        "title": "Git Shortcuts Doctor: Stash Push",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.stashPop",
        "title": "Git Shortcuts Doctor: Stash Pop",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.abortMerge",
        "title": "Git Shortcuts Doctor: Abort Merge",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.abortRebase",
        "title": "Git Shortcuts Doctor: Abort Rebase",
        "category": "Git Shortcuts Doctor"
      },
      {
        "command": "gitShortcutsDoctor.acceptCurrent",
        "title": "Git Shortcuts Doctor: Accept Current Change",
